{
  "name": "nextjs-mongoose-boilerplate",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "check": "bun run format:check && bun run lint",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "version": "auto-changelog -p && git add CHANGELOG.md",
    "deploy:beta": "npm version prerelease -m 'Release Beta v%s' --preid=beta",
    "deploy:production": "npm version patch -m 'Release v%s'",
    "deploy:minor:production": "npm version minor -m 'Release v%s'",
    "deploy:major:production": "npm version major -m 'Release v%s'",
    "postversion": "git push && git push --follow-tags"
  },
  "dependencies": {
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@sentry/nextjs": "^10.47.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cookie": "^1.1.1",
    "jose": "^6.2.2",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sequelize": "^6.37.8",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@next/eslint-plugin-next": "^16.2.2",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "auto-changelog": "^2.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.1.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}